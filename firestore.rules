rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(authorId) {
      return isAuthenticated() && request.auth.uid == authorId;
    }
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "firsticychen@gmail.com" && request.auth.token.email_verified == true);
    }

    // Validation functions
    function isValidPost(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 50000 &&
             data.category in ['Learning', 'Essay'];
    }

    function isValidAnime(data) {
      return data.name is string && data.name.size() > 0 &&
             data.score is number && data.score >= 0 && data.score <= 10;
    }

    function isValidDiary(data) {
      return data.content is string && data.content.size() > 0;
    }

    // Rules
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAdmin() && isValidPost(request.resource.data);
      allow update: if isAdmin() && isValidPost(request.resource.data);
      allow delete: if isAdmin();
    }

    match /anime/{animeId} {
      allow read: if true;
      allow create: if isAdmin() && isValidAnime(request.resource.data);
      allow update: if isAdmin() && isValidAnime(request.resource.data);
      allow delete: if isAdmin();
    }

    match /diaries/{diaryId} {
      allow read: if isOwner(resource.data.authorId);
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid && isValidDiary(request.resource.data);
      allow update: if isOwner(resource.data.authorId) && isValidDiary(request.resource.data);
      allow delete: if isOwner(resource.data.authorId);
    }

    match /friends/{friendId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
    }
  }
}
